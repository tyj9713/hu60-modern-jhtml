  "description": "Modern responsive JHTML theme for hu60wap6",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyj9713/hu60-modern-jhtml.git"
  },
  "homepage": "https://github.com/tyj9713/hu60-modern-jhtml#readme",
  "bugs": {
