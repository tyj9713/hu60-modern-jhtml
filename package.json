    "check": "pnpm test && pnpm build && pnpm verify:dist && pnpm test:browser",
    "prepublishOnly": "pnpm test && pnpm build && pnpm verify:dist && pnpm test:browser"
  },
  "dependencies": {
    "@astral-sh/ruff-wasm-web": "0.15.22",
    "@prettier/plugin-php": "0.25.0",
    "dompurify": "3.4.12",
    "fast-diff": "1.3.0",
    "highlight.js": "11.11.1",
    "prettier": "3.9.5",
    "prettier-plugin-sh": "0.19.0",
    "sh-syntax": "0.6.0",
    "sql-formatter": "15.8.2"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "29.1.1",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
