  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/app.min.js",
    "./theme.css": "./dist/theme.min.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
